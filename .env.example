# Copy this file to .env.local for local development.
# In production (Vercel), set the SAME variable names under
# Project Settings -> Environment Variables.

# --- Server-side (used by server.ts / api/index.ts) ---
# Google Gemini API key. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# SerpApi key for live Google Israel SERP data (real competitors, PAA, related
# searches). Get it from https://serpapi.com/dashboard. Optional: when empty,
# competitor analysis falls back to Gemini-only estimates.
SERPAPI_KEY=

# --- Client-side Firebase config (used by src/lib/firebaseHelper.ts) ---
# Get these from Firebase Console -> Project Settings -> General -> Your apps -> SDK setup and configuration
# NOTE: Vite only exposes variables prefixed with VITE_ to client-side code.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: only needed if you use a named (non-default) Firestore database
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# --- Manual connection slot: Google Search Console (read-only, free) ---
# The verified Search Console property to read real performance data for.
# Use the "sc-domain:" prefix for a domain property, or the full URL for a
# URL-prefix property. Leave empty to keep the connection dormant.
# Also requires: enable "Google Search Console API" in Google Cloud and
# uncomment the webmasters.readonly scope in src/lib/firebaseHelper.ts.
# Example: sc-domain:heartcompass.vercel.app
VITE_GSC_SITE_URL=
